ifeq ($(filter /%,$(src)),)
KSU_KERNEL_DIR := $(srctree)/$(src)
else
KSU_KERNEL_DIR := $(src)
endif

ccflags-y += -I$(KSU_KERNEL_DIR) -I$(KSU_KERNEL_DIR)/include

obj-$(CONFIG_KSU) += kernelsu.o

MDIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))

# ------------------------------------------------------------
# BunnySU driver ABI version
#
# Do NOT bind this to every git commit.
# Manager can increase by app/UI commits, but driver should only
# increase when kernel/root API actually changes.
#
# 32377 is the minimum required version shown by current Manager.
# This avoids:
# - fallback 30000 too low
# - chasing 32495, 32496, 32497 every commit
# ------------------------------------------------------------

ifndef KSU_VERSION
KSU_VERSION := 32377
endif

$(info -- BunnySU driver version: $(KSU_VERSION))
ccflags-y += -DKSU_VERSION=$(KSU_VERSION)

# ------------------------------------------------------------
# BunnySU dcache flush detection
# ------------------------------------------------------------

KSU_NEW_DCACHE_FLUSH := $(shell grep -q __flush_dcache_area $(srctree)/arch/arm64/include/asm/cacheflush.h ; echo $$?)
$(info -- KSU_NEW_DCACHE_FLUSH: $(KSU_NEW_DCACHE_FLUSH))

# ------------------------------------------------------------
# BunnySU Manager signature
#
# WARNING:
# These default values are PR/test signature values.
# If you keep them, Manager may still show PR signature warning.
#
# To remove that warning properly, replace these with the real
# signature size/hash of your signed BunnySU Manager APK.
# ------------------------------------------------------------

ifndef KSU_EXPECTED_SIZE
KSU_EXPECTED_SIZE := 0x033b
endif

ifndef KSU_EXPECTED_HASH
KSU_EXPECTED_HASH := c371061b19d8c7d7d6133c6a9bafe198fa944e50c1b31c9d8daa8d7f1fc2d2d6
endif

ifdef KSU_MANAGER_PACKAGE
ccflags-y += -DKSU_MANAGER_PACKAGE=\"$(KSU_MANAGER_PACKAGE)\"
$(info -- BunnySU Manager package name: $(KSU_MANAGER_PACKAGE))
endif

$(info -- BunnySU Manager signature size: $(KSU_EXPECTED_SIZE))
$(info -- BunnySU Manager signature hash: $(KSU_EXPECTED_HASH))

ccflags-y += -DEXPECTED_SIZE=$(KSU_EXPECTED_SIZE)
ccflags-y += -DEXPECTED_HASH=\"$(KSU_EXPECTED_HASH)\"

ifdef KSU_EXPECTED_SIZE2
ifndef KSU_EXPECTED_HASH2
$(error KSU_EXPECTED_HASH2 must be set when KSU_EXPECTED_SIZE2 is set)
endif

ccflags-y += -DEXPECTED_SIZE2=$(KSU_EXPECTED_SIZE2)
ccflags-y += -DEXPECTED_HASH2=\"$(KSU_EXPECTED_HASH2)\"

$(info -- BunnySU Manager signature size2: $(KSU_EXPECTED_SIZE2))
$(info -- BunnySU Manager signature hash2: $(KSU_EXPECTED_HASH2))
endif

ccflags-y += -DKSU_NEW_DCACHE_FLUSH=$(KSU_NEW_DCACHE_FLUSH)

ccflags-y += -Wno-strict-prototypes -Wno-int-conversion -Wno-gcc-compat -Wno-missing-prototypes
ccflags-y += -Wno-declaration-after-statement -Wno-unused-function

